{
  "name": "the-safe-place-chronicles-the-echo-of-the-journey",
  "private": true,
  "version": "2.0.16",
  "type": "module",
  "description": "The Safe Place Chronicles: The Echo of the Journey — un GDR testuale post-apocalittico.",
  "author": "Runtime Radio <noreply@runtimeradio.it>",
  "homepage": "https://github.com/Pitz72/TheSafePlace-React",
  "repository": {
    "type": "git",
    "url": "https://github.com/Pitz72/TheSafePlace-React.git"
  },
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest",
    "validate:data": "node scripts/validate-data.js",
    "compile:ink": "inkjs-compiler -o src/assets/story/main.json src/assets/story/main.ink",
    "predev": "npm run compile:ink",
    "prebuild": "npm run compile:ink",
    "lint": "eslint .",
    "electron": "electron .",
    "electron:dev": "electron . --dev",
    "dist": "npm run build && electron-builder",
    "dist:dir": "npm run build && electron-builder --dir",
    "dist:win": "npm run build && electron-builder --win",
    "dist:mac": "npm run build && electron-builder --mac",
    "dist:linux": "npm run build && electron-builder --linux"
  },
  "build": {
    "appId": "com.runtimeradio.thesafeplace",
    "productName": "The Safe Place",
    "copyright": "© Runtime Radio 2025",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "asar": true,
    "publish": [
      {
        "provider": "github",
        "owner": "Pitz72",
        "repo": "TheSafePlace-React"
      }
    ],
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "artifactName": "TheSafePlace-${version}-win-${arch}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.role-playing-games",
      "artifactName": "TheSafePlace-${version}-mac-${arch}.${ext}"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Game",
      "maintainer": "Runtime Radio <noreply@runtimeradio.it>",
      "synopsis": "GDR testuale di sopravvivenza post-apocalittico",
      "artifactName": "TheSafePlace-${version}-linux-${arch}.${ext}"
    }
  },
  "dependencies": {
    "eventemitter3": "^5.0.1",
    "inkjs": "^2.3.2",
    "phaser": "^3.90.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "zod": "^4.1.12",
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^22.18.11",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^5.0.0",
    "autoprefixer": "^10.4.18",
    "electron": "^43.1.0",
    "electron-builder": "^26.15.3",
    "eslint": "^9.39.1",
    "globals": "^16.5.0",
    "jsdom": "^27.0.1",
    "postcss": "^8.4.35",
    "tailwindcss": "^3.4.1",
    "ts-node": "^10.9.2",
    "typescript": "~5.8.2",
    "vite": "^6.2.0",
    "vitest": "^3.2.4"
  }
}
